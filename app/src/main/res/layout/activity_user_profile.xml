<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- AppBar dengan header profil -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="#1B5E20">

            <!-- Background header (Profil Info) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1B5E20"
                android:paddingTop="40dp"
                android:paddingBottom="20dp"
                app:layout_collapseMode="parallax">

                <!-- Foto profil (avatar) -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="45dp"
                        app:cardElevation="6dp">

                        <ImageView
                            android:id="@+id/iv_profile_photo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:contentDescription="@string/profile_photo_desc"
                            android:scaleType="centerCrop" />

                    </androidx.cardview.widget.CardView>

                    <!-- Tombol edit foto -->
                    <ImageView
                        android:id="@+id/iv_edit_photo"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:contentDescription="@string/edit_photo_desc"
                        android:background="@android:color/white"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_gravity="bottom|end"
                        android:backgroundTint="@android:color/white"
                        app:tint="#1B5E20" />

                </FrameLayout>

                <!-- Nama pengguna -->
                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_user_name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="12dp" />

                <!-- Email pengguna -->
                <TextView
                    android:id="@+id/tv_profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_user_email"
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:alpha="0.8"
                    android:layout_marginTop="4dp" />

                <!-- Badge terverifikasi -->
                <TextView
                    android:id="@+id/tv_verified_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/verified_label"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:background="#2E7D32"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Toolbar (untuk back button) -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar_profile"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@android:drawable/ic_menu_revert"
                app:title="" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Konten scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="80dp">

            <!-- Card: Statistik Pengguna -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Stat 1: Total Listing -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_total_listing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_count"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_lands_on_sale"
                            android:textSize="12sp"
                            android:textColor="#777777" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E0E0E0"
                        android:layout_gravity="center_vertical" />

                    <!-- Stat 2: Lahan Terjual -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_sold_listing"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_count"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_sold"
                            android:textSize="12sp"
                            android:textColor="#777777" />

                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E0E0E0"
                        android:layout_gravity="center_vertical" />

                    <!-- Stat 3: Rating -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_rating"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_rating"
                            android:textSize="12sp"
                            android:textColor="#777777" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card: Informasi Akun -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_account_info"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:layout_marginBottom="12dp" />

                    <!-- Item: Nama -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="48dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="@string/symbol_user"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_full_name"
                                android:textSize="11sp"
                                android:textColor="#888888" />

                            <TextView
                                android:id="@+id/tv_info_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/iv_edit_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/edit_label"
                            android:textSize="12sp"
                            android:textColor="#1B5E20"
                            android:clickable="true"
                            android:focusable="true"
                            android:minHeight="48dp"
                            android:gravity="center_vertical" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <!-- Item: Telepon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="48dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="@string/symbol_phone"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_phone"
                                android:textSize="11sp"
                                android:textColor="#888888" />

                            <TextView
                                android:id="@+id/tv_info_phone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/iv_edit_phone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/edit_label"
                            android:textSize="12sp"
                            android:textColor="#1B5E20"
                            android:clickable="true"
                            android:focusable="true"
                            android:minHeight="48dp"
                            android:gravity="center_vertical" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <!-- Item: Email -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="48dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="@string/symbol_email"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_email"
                                android:textSize="11sp"
                                android:textColor="#888888" />

                            <TextView
                                android:id="@+id/tv_info_email"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                android:textSize="14sp"
                                android:textColor="#333333" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Header Lahan Saya -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_my_lands"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/tv_see_all_land"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all_label"
                    android:textSize="13sp"
                    android:textColor="#1B5E20"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="48dp"
                    android:gravity="center_vertical" />

            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_my_listings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/ll_empty_listing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/symbol_plant"
                    android:textSize="48sp"
                    android:gravity="center"
                    android:alpha="0.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_lands_message"
                    android:textSize="14sp"
                    android:textColor="#999999"
                    android:layout_marginTop="12dp" />

                <Button
                    android:id="@+id/btn_add_first_land"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/btn_add_land"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1B5E20"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

            <!-- Card: Menu Pengaturan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_settings"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#222222"
                        android:layout_marginBottom="8dp" />

                    <!-- Menu: Ubah Password -->
                    <LinearLayout
                        android:id="@+id/ll_change_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:minHeight="48dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="@string/symbol_lock"
                            android:gravity="center"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_change_password"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symbol_arrow_right"
                            android:textSize="20sp"
                            android:textColor="#AAAAAA" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <!-- Menu: Notifikasi -->
                    <LinearLayout
                        android:id="@+id/ll_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:minHeight="48dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="@string/symbol_notif"
                            android:gravity="center"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_notifications"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symbol_arrow_right"
                            android:textSize="20sp"
                            android:textColor="#AAAAAA" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                    <!-- Menu: Bantuan -->
                    <LinearLayout
                        android:id="@+id/ll_help"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:minHeight="48dp">

                        <TextView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:text="@string/symbol_help"
                            android:gravity="center"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/menu_help"
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/symbol_arrow_right"
                            android:textSize="20sp"
                            android:textColor="#AAAAAA" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tombol Logout -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_logout_label"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#D32F2F" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>