<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_tanah"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="190dp">

            <ImageView
                android:id="@+id/iv_foto_tanah"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#DCE8D5"
                android:contentDescription="Foto tanah"
                android:scaleType="centerCrop"
                android:src="@drawable/lahan_kavling" />

            <TextView
                android:id="@+id/tv_badge_sertifikat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="#E8F5E9"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Verified SHM"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layout_content_tanah"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_harga_tanah"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp 2.450.000.000"
                android:textColor="#1B5E20"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_lokasi_tanah"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Margonda, Depok"
                android:textColor="#444444"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/layout_info_tanah"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_luas_tanah"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Luas: 200 m²"
                    android:textColor="#666666"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_kategori_tanah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#F1F8E9"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="Hunian"
                    android:textColor="#558B2F"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_deskripsi_tanah"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Tanah strategis dekat jalan utama, cocok untuk hunian, investasi, atau usaha."
                android:textColor="#777777"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_lihat_detail"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#1B5E20"
                android:text="Lihat Detail"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>