<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_list_tanah"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F3"
    android:orientation="vertical">

    <!-- Header hijau -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#1B5E20"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tv_list_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eksplorasi Lahan"
            android:textColor="#DDEBDD"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_title_list_tanah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Daftar Tanah"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitle_list_tanah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Temukan tanah strategis sesuai kebutuhan Anda"
            android:textColor="#E8F5E9"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Search bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_search_tanah"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="-24dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="5dp">

        <EditText
            android:id="@+id/et_search_tanah"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@android:color/transparent"
            android:hint="Cari lokasi tanah..."
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#222222"
            android:textColorHint="#999999"
            android:textSize="14sp" />
    </androidx.cardview.widget.CardView>

    <!-- Filter / tab -->
    <HorizontalScrollView
        android:id="@+id/hsv_filter_tanah"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_filter_tanah"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_filter_semua"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:backgroundTint="#1B5E20"
                android:text="Semua"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_shm"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="SHM"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_hgb"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="HGB"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_termurah"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="Termurah"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_terdekat"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="Terdekat"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_sawah"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="Sawah"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_kavling"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="Kavling"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_filter_industri"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E8F5E9"
                android:text="Industri"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Info hasil -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tv_rekomendasi_tanah"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Listing Tersedia"
            android:textColor="#222222"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_jumlah_listing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="24 Tanah"
            android:textColor="#1B5E20"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_info_listing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Menampilkan tanah dengan legalitas dan informasi awal yang lengkap"
        android:textColor="#777777"
        android:textSize="12sp" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_list_tanah"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        tools:itemCount="4"
        tools:listitem="@layout/item_tanah_card" />

</LinearLayout>